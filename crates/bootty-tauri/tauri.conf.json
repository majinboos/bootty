{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Bootty Web Terminal",
  "version": "0.0.0",
  "identifier": "dev.bootty.web-terminal",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "dist"
  },
  "app": {
    "windows": [
      {
        "title": "Bootty Web Terminal",
        "width": 960,
        "height": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": [],
    "targets": "all"
  }
}